{
  "manifest_version": 3,
  "name": "Simple Chrome Extension",
  "version": "0.1.0",
  "description": "Display a list of all open tabs in a new tab.",
  "permissions": ["tabs"],
  "action": {},
  "background": {
    "service_worker": "background/background.js"
  },
  "chrome_url_overrides": {
    "newtab": "dist/index.html"
  }
}
